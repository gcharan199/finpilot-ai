{
  "expo": {
    "name": "FinPilot",
    "slug": "finpilot-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "finpilot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0e0c"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.finpilot.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "FinPilot uses Face ID to unlock your financial data.",
        "NSCameraUsageDescription": "FinPilot uses the camera to scan receipts.",
        "NSPhotoLibraryUsageDescription": "FinPilot reads receipt images you pick from your library."
      }
    },
    "android": {
      "package": "ai.finpilot.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0e0c"
      },
      "permissions": ["CAMERA", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        { "faceIDPermission": "FinPilot uses Face ID to unlock your financial data." }
      ],
      [
        "expo-camera",
        { "cameraPermission": "FinPilot uses the camera to scan receipts." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "FinPilot reads receipt images you pick from your library." }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
