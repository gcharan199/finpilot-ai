{
  "name": "@finpilot/database",
  "version": "0.1.0",
  "description": "Drizzle SQLite schema + dependency-injected repositories for FinPilot AI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@finpilot/finance-engine": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "better-sqlite3": "^11.7.0",
    "drizzle-kit": "^0.30.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
