# Dev-only fallback Gemini API key. The app prefers a key entered in Settings
# (stored in expo-secure-store); this EXPO_PUBLIC_ var is only a convenience for
# local development. NOTE: EXPO_PUBLIC_* values are inlined into the JS bundle —
# do not ship a real key this way in production.
EXPO_PUBLIC_GEMINI_API_KEY=

# Optional model override (defaults to gemini-2.5-flash).
EXPO_PUBLIC_GEMINI_MODEL=
